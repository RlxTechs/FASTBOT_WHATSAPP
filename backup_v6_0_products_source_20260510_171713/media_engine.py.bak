import json
import time
from pathlib import Path
from typing import Any, Dict, List

from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from bot_core import normalize, get_state

try:
    from app_paths import BASE_DIR
except Exception:
    BASE_DIR = Path(__file__).resolve().parent

MEDIA_PATH = BASE_DIR / "media_catalog.json"

IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".webp"}

def load_json(path: Path, default: Any):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def media_data() -> Dict[str, Any]:
    return load_json(MEDIA_PATH, {"enabled": False, "bundles": []})

def existing_images(paths: List[str]) -> List[str]:
    found = []
    for p in paths:
        full = BASE_DIR / p
        if full.exists() and full.is_file() and full.suffix.lower() in IMAGE_EXTS:
            found.append(str(full.resolve()))
    return found

def score_bundle(bundle: Dict[str, Any], message: str, state: Dict[str, Any], result: Dict[str, Any]) -> int:
    if not bundle.get("active", True):
        return -999

    msg = normalize(message)
    score = 0

    # Mots-clés dans message client
    for kw in bundle.get("keywords", []):
        kn = normalize(kw)
        if kn and kn in msg:
            score += 5

    # Contexte campagne / catégorie
    contexts = [normalize(x) for x in bundle.get("contexts", [])]
    state_values = [
        state.get("campaign_id", ""),
        state.get("campaign_category", ""),
        state.get("last_category", ""),
        state.get("campaign_label", ""),
        state.get("campaign_product_query", ""),
        state.get("last_product_id", ""),
        state.get("campaign_product_id", "")
    ]

    state_text = normalize(" ".join(str(x) for x in state_values))
    for ctx in contexts:
        if ctx and ctx in state_text:
            score += 4

    # Intent / réponse générée
    intent = normalize(str(result.get("intent", "")))
    reply = normalize(str(result.get("reply", "")))
    for kw in bundle.get("keywords", []):
        kn = normalize(kw)
        if kn and (kn in intent or kn in reply):
            score += 2

    return score

def select_media_for_reply(message: str, chat_id: str, result: Dict[str, Any]) -> List[str]:
    data = media_data()
    if not data.get("enabled", True):
        return []

    state = get_state(chat_id)
    bundles = data.get("bundles", [])
    global_max = int(data.get("max_images_per_reply", 3))

    scored = []
    for b in bundles:
        imgs = existing_images(b.get("image_paths", []))
        if not imgs:
            continue

        score = score_bundle(b, message, state, result)
        if score > 0:
            scored.append((score, b, imgs))

    if not scored:
        return []

    scored.sort(key=lambda x: x[0], reverse=True)

    selected = []
    for score, bundle, imgs in scored:
        max_images = int(bundle.get("max_images", global_max))
        for img in imgs[:max_images]:
            if img not in selected:
                selected.append(img)
            if len(selected) >= global_max:
                return selected

    return selected[:global_max]

def find_file_input(driver):
    inputs = driver.find_elements(By.CSS_SELECTOR, "input[type='file']")
    for inp in inputs:
        try:
            return inp
        except Exception:
            pass
    return None

def click_attach_button(driver):
    selectors = [
        "span[data-icon='plus']",
        "span[data-icon='clip']",
        "div[title='Joindre']",
        "div[title='Attach']",
        "button[title='Attach']",
        "button[aria-label='Attach']",
        "button[aria-label='Joindre']"
    ]

    for css in selectors:
        try:
            els = driver.find_elements(By.CSS_SELECTOR, css)
            for el in els:
                if el.is_displayed():
                    el.click()
                    time.sleep(0.5)
                    return True
        except Exception:
            continue

    return False

def send_media_files(driver, image_paths: List[str], caption: str = "") -> Dict[str, Any]:
    """
    Envoie des images dans WhatsApp Web.
    Note : WhatsApp change souvent ses sélecteurs. Si ça échoue, le log dira où.
    """
    if not image_paths:
        return {"sent": 0, "error": ""}

    sent = 0
    errors = []

    for img in image_paths:
        try:
            click_attach_button(driver)
            time.sleep(0.5)

            file_input = find_file_input(driver)
            if not file_input:
                errors.append("input_file_introuvable")
                continue

            file_input.send_keys(img)
            time.sleep(1.5)

            # Si une zone de légende existe et caption demandé
            if caption:
                try:
                    boxes = driver.find_elements(By.CSS_SELECTOR, "div[contenteditable='true'][role='textbox']")
                    if boxes:
                        boxes[-1].click()
                        boxes[-1].send_keys(caption)
                except Exception:
                    pass

            # Envoyer
            sent_ok = False
            send_selectors = [
                "span[data-icon='send']",
                "span[data-icon='wds-ic-send-filled']",
                "button[aria-label='Envoyer']",
                "button[aria-label='Send']"
            ]

            for css in send_selectors:
                try:
                    btns = driver.find_elements(By.CSS_SELECTOR, css)
                    for btn in btns:
                        if btn.is_displayed():
                            btn.click()
                            sent += 1
                            sent_ok = True
                            time.sleep(1.0)
                            break
                    if sent_ok:
                        break
                except Exception:
                    continue

            if not sent_ok:
                try:
                    boxes = driver.find_elements(By.CSS_SELECTOR, "div[contenteditable='true'][role='textbox']")
                    if boxes:
                        boxes[-1].send_keys(Keys.ENTER)
                        sent += 1
                        time.sleep(1.0)
                    else:
                        errors.append("bouton_send_introuvable")
                except Exception as e:
                    errors.append("send_failed:" + repr(e))

        except Exception as e:
            errors.append(repr(e))

    return {"sent": sent, "error": "; ".join(errors)}
