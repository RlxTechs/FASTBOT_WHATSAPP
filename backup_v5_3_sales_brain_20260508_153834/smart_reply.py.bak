from typing import Dict, Any
import json
from pathlib import Path

from bot_core import (
    generate_reply,
    get_state,
    find_product_by_id,
    price,
    normalize
)

from intent_bank import (
    try_intent_bank_reply,
    should_return_bank_before_product,
    record_unknown_message
)

BASE_DIR = Path(__file__).resolve().parent
SALES_CONFIG_PATH = BASE_DIR / "sales_config.json"

def load_json(path: Path, default: Any) -> Any:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def cfg() -> Dict[str, Any]:
    return load_json(SALES_CONFIG_PATH, {})

def is_food_context(state: Dict) -> bool:
    return (
        state.get("campaign_category") == "food"
        or state.get("last_category") == "food"
        or state.get("campaign_id") == "menu_food"
    )

def is_greeting(msg_norm: str) -> bool:
    return msg_norm in {
        "bonjour", "bonsoir", "salut", "bjr", "bsr", "hello", "allo", "slt", "cc", "coucou"
    }

def is_facebook_generic_more_info(msg_norm: str) -> bool:
    checks = [
        "puis je en savoir plus",
        "je peux en savoir plus",
        "en savoir plus",
        "plus a ce sujet",
        "plus à ce sujet",
        "ce sujet",
        "a ce sujet",
        "à ce sujet"
    ]
    return any(x in msg_norm for x in checks)

def is_vague_context_message(msg_norm: str) -> bool:
    vague_words = [
        "prix", "combien", "cest combien", "c est combien", "dispo", "disponible",
        "ca coute", "ça coute", "je veux", "interesse", "intéressé", "interesser",
        "c est disponible", "oui", "ok", "comment", "infos", "info",
        "savoir plus", "plus a ce sujet", "plus à ce sujet"
    ]
    return any(w in msg_norm for w in vague_words) and len(msg_norm.split()) <= 14

def asks_location(msg_norm: str) -> bool:
    checks = [
        "vous etes ou", "ou etes vous", "ou se trouve", "adresse", "localisation",
        "emplacement", "boutique", "magasin", "restaurant", "dans quel ville",
        "dans quelle ville", "quel ville", "quelle ville", "situe ou", "situer ou", "ville"
    ]
    return any(x in msg_norm for x in checks)

def asks_delivery(msg_norm: str) -> bool:
    checks = [
        "livraison", "livrez", "livrer", "domicile", "frais", "transport",
        "deplacement", "déplacement", "chez moi"
    ]
    return any(x in msg_norm for x in checks)

def asks_order(msg_norm: str) -> bool:
    checks = [
        "commander", "commande", "je prends", "je veux prendre", "reserver",
        "réserver", "acheter", "valider", "livrez moi"
    ]
    return any(x in msg_norm for x in checks)

def asks_price_or_menu(msg_norm: str) -> bool:
    checks = [
        "prix", "combien", "menu", "plat", "nourriture", "manger", "alloco",
        "chawarma", "riz", "thieb", "yassa", "frites", "banane"
    ]
    return any(x in msg_norm for x in checks)

def food_menu_text(prefix: str = "") -> str:
    c = cfg()
    food = c.get("food", {})
    lines = []

    if prefix.strip():
        lines.append(prefix.strip())
        lines.append("")

    lines.append(food.get("brand_line", "Nos plats sont spéciaux 🔥🍗🍟🍲🛒"))
    lines.append(food.get("delivery_only_line", "On fait uniquement par livraison. 🚚"))
    lines.append("")
    lines.append("Voici le menu disponible :")

    for item in food.get("items", []):
        lines.append(f"• {item.get('name')} — {item.get('price')}")

    lines.append("")
    lines.append(food.get("delivery_note", "Livraison selon votre zone."))
    lines.append("")
    lines.append(food.get("order_cta", "Pour commander, envoyez le plat choisi + votre quartier + votre numéro."))

    return "\n".join(lines).strip()

def food_reply_for_message(msg_norm: str) -> str:
    if asks_location(msg_norm):
        return food_menu_text("On fait uniquement par livraison, pas de retrait boutique pour les plats.")

    if asks_delivery(msg_norm):
        return food_menu_text("Oui, livraison disponible selon votre zone.")

    if asks_order(msg_norm):
        return (
            "Parfait 🔥 Pour commander, envoyez :\n"
            "1) Le plat choisi\n"
            "2) Votre quartier\n"
            "3) Votre numéro\n"
            "4) Adresse précise\n\n"
            + food_menu_text("Voici le menu pour choisir rapidement :")
        )

    if is_greeting(msg_norm) or is_facebook_generic_more_info(msg_norm) or is_vague_context_message(msg_norm) or asks_price_or_menu(msg_norm):
        return food_menu_text("Bonjour 👋 Vous venez sûrement de la Pub Menu nourriture. 🍽️")

    return ""

def unknown_campaign_admin_reply(state: Dict) -> Dict:
    return {
        "reply": "",
        "confidence": 0.0,
        "intent": "unknown_facebook_campaign_waiting_admin",
        "safe_to_auto_send": False,
        "debug": {
            "blocked_reason": "Facebook ad card detected but campaign is not labeled yet",
            "unknown_hash": state.get("unknown_campaign_hash", ""),
            "unknown_image": state.get("unknown_campaign_image", ""),
            "admin_action": "Open admin_campaign_gui.bat and assign the thumbnail"
        }
    }

def non_food_location_reply() -> str:
    return cfg().get("non_food", {}).get(
        "location_reply",
        "O'CG / BZ STORE est à Brazzaville. 📍\nVous souhaitez être livré ou venir récupérer chez nous ?"
    )

def non_food_delivery_reply() -> str:
    return cfg().get("non_food", {}).get(
        "delivery_reply",
        "Oui, livraison possible à Brazzaville. Envoyez votre quartier + l’article voulu."
    )

def add_sales_cta(reply: str, state: Dict) -> str:
    if not reply:
        return reply

    if is_food_context(state):
        return reply

    cta = cfg().get("non_food", {}).get("sales_cta", "")
    if not cta:
        return reply

    low = reply.lower()
    if "envoyez votre quartier" in low or "vous souhaitez être livré" in low or "venir récupérer" in low:
        return reply

    return reply.rstrip() + "\n\n" + cta

def product_context_reply(state: Dict, chat_id: str) -> str:
    label = state.get("campaign_label") or "la pub"
    product_id = state.get("campaign_product_id") or state.get("last_product_id")

    if product_id:
        p = find_product_by_id(product_id)
        if p:
            variants = p.get("variants", []) or []
            title = p.get("title", "cet article")
            availability = p.get("availability", "Disponible")
            max_v = int(cfg().get("sales_rules", {}).get("max_variants_in_reply", 10))

            if variants:
                lines = [f"Bonjour 👋 Vous venez sûrement de la {label}. Voici les options disponibles :"]
                for v in variants[:max_v]:
                    lines.append(f"• {v.get('name')} — {price(v.get('price'))}")
                lines.append(f"\nDisponibilité : {availability}.")
                lines.append("Vous souhaitez être livré ou venir récupérer chez nous ?")
                lines.append("Envoyez le modèle exact + votre quartier pour confirmer rapidement.")
                return "\n".join(lines)

            return (
                f"Bonjour 👋 Vous venez sûrement de la {label}.\n"
                f"{title} — {price(p.get('basePrice', 0))}.\n"
                f"Disponibilité : {availability}.\n\n"
                "Vous souhaitez être livré ou venir récupérer chez nous ?"
            )

    return ""

def category_context_reply(state: Dict, chat_id: str) -> str:
    label = state.get("campaign_label") or "la pub"
    category = state.get("campaign_category") or state.get("last_category") or ""
    query = state.get("campaign_product_query") or ""

    if category == "food":
        return food_menu_text("Bonjour 👋 Vous venez sûrement de la Pub Menu nourriture. 🍽️")

    if category == "tv":
        base = generate_reply("tv", chat_id=chat_id).get("reply", "")
        return add_sales_cta(f"Bonjour 👋 Vous venez sûrement de la {label}. 📺\n\n{base}", state)

    if category == "energie":
        base = generate_reply(query or "groupe electrogene", chat_id=chat_id).get("reply", "")
        return add_sales_cta(f"Bonjour 👋 Vous venez sûrement de la {label}. ⚡\n\n{base}", state)

    if category == "refrigerateur":
        base = generate_reply(query or "refrigerateur", chat_id=chat_id).get("reply", "")
        return add_sales_cta(f"Bonjour 👋 Vous venez sûrement de la {label}. 🧊\n\n{base}", state)

    if category == "congelateur":
        base = generate_reply(query or "congelateur", chat_id=chat_id).get("reply", "")
        return add_sales_cta(f"Bonjour 👋 Vous venez sûrement de la {label}. 🧊\n\n{base}", state)

    if category == "split":
        base = generate_reply(query or "climatiseur split", chat_id=chat_id).get("reply", "")
        return add_sales_cta(f"Bonjour 👋 Vous venez sûrement de la {label}. ❄️\n\n{base}", state)

    if category == "iphones":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 📱\n"
            "Nous avons plusieurs séries iPhone disponibles.\n"
            "Envoyez le modèle exact voulu, par exemple : iPhone 13 Pro Max, iPhone 15 Pro, iPhone 16 Pro Max.\n\n"
            "Vous souhaitez être livré ou venir récupérer chez nous ?"
        )

    if category == "services":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 👨🏽‍💻\n"
            "Nous proposons plusieurs services : installation Windows, Pack Office, site web, application mobile, automatisation, cybersécurité.\n"
            "Dites-moi le service voulu et je vous donne le prix."
        )

    if category == "electromenager":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 🏠\n"
            "Nous avons plusieurs articles électroménagers : frigo, congélateur, split/climatiseur, micro-onde, machine à laver.\n"
            "Dites-moi l’article voulu ou envoyez la capacité/taille.\n\n"
            "Vous souhaitez être livré ou venir récupérer chez nous ?"
        )

    return ""

def context_reply(state: Dict, chat_id: str) -> str:
    if is_food_context(state):
        return food_menu_text("Bonjour 👋 Vous venez sûrement de la Pub Menu nourriture. 🍽️")

    p = product_context_reply(state, chat_id)
    if p:
        return p

    c = category_context_reply(state, chat_id)
    if c:
        return c

    label = state.get("campaign_label")
    if label:
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}.\n"
            "Dites-moi ce que vous voulez savoir : prix, disponibilité, livraison ou commande."
        )

    return ""

def generate_smart_reply(message: str, chat_id: str = "default") -> Dict:
    state = get_state(chat_id)
    msg_norm = normalize(message)

    # 1) Pub inconnue = blocage total.
    if state.get("needs_campaign_label"):
        result = unknown_campaign_admin_reply(state)
        record_unknown_message(message, chat_id, "unknown_facebook_campaign_waiting_admin", state, result)
        return result

    has_campaign_context = bool(state.get("campaign_id") or state.get("campaign_label"))

    # 2) Message Facebook générique sans contexte = blocage.
    if is_facebook_generic_more_info(msg_norm) and not has_campaign_context:
        result = {
            "reply": "",
            "confidence": 0.0,
            "intent": "waiting_facebook_campaign_context",
            "safe_to_auto_send": False,
            "debug": {
                "blocked_reason": "Generic Facebook greeting requires campaign context before replying"
            }
        }
        record_unknown_message(message, chat_id, "facebook_more_info_without_campaign_context", state, result)
        return result

    # 3) Food priorité absolue.
    if is_food_context(state):
        reply = food_reply_for_message(msg_norm)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.95,
                "intent": "food_context_delivery_menu",
                "safe_to_auto_send": True,
                "debug": {
                    "source": "food_priority",
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label")
                }
            }

    # 4) Non-food localisation/livraison selon contexte boutique.
    if not is_food_context(state) and asks_location(msg_norm):
        return {
            "reply": non_food_location_reply(),
            "confidence": 0.93,
            "intent": "non_food_location",
            "safe_to_auto_send": True,
            "debug": {"source": "context_location_non_food"}
        }

    if not is_food_context(state) and asks_delivery(msg_norm):
        return {
            "reply": non_food_delivery_reply(),
            "confidence": 0.93,
            "intent": "non_food_delivery",
            "safe_to_auto_send": True,
            "debug": {"source": "context_delivery_non_food"}
        }

    # 5) Contexte pub connu + message vague = réponse liée à la pub.
    if has_campaign_context and (is_greeting(msg_norm) or is_vague_context_message(msg_norm)):
        reply = context_reply(state, chat_id)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.93,
                "intent": "campaign_context_reply",
                "safe_to_auto_send": True,
                "debug": {
                    "source": "campaign_context",
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label"),
                    "campaign_category": state.get("campaign_category")
                }
            }

    # 6) Banque d’intentions commerciales.
    bank = try_intent_bank_reply(message, chat_id=chat_id)

    if should_return_bank_before_product(bank):
        if bank.get("reply"):
            bank["reply"] = add_sales_cta(bank["reply"], state)
        return bank

    # 7) Moteur produit.
    result = generate_reply(message, chat_id=chat_id)

    if result.get("reply"):
        result["reply"] = add_sales_cta(result["reply"], state)

    # 8) Si moteur vague mais banque a compris.
    if result.get("intent") in {"clarify_product", "vague_price", "smalltalk_or_noise"} and bank:
        if bank.get("reply"):
            bank["reply"] = add_sales_cta(bank["reply"], state)
        return bank

    # 9) Si contexte pub connu mais réponse vague.
    if has_campaign_context and result.get("intent") in {"clarify_product", "vague_price", "smalltalk_or_noise"}:
        reply = context_reply(state, chat_id)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.91,
                "intent": "campaign_context_fallback",
                "safe_to_auto_send": True,
                "debug": {
                    "original_intent": result.get("intent"),
                    "source": "campaign_context_fallback",
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label")
                }
            }

    # 10) Apprentissage des inconnus.
    try:
        conf = float(result.get("confidence", 0))
    except Exception:
        conf = 0

    if result.get("intent") in {"clarify_product", "smalltalk_or_noise"} or conf < 0.50:
        record_unknown_message(message, chat_id, "low_confidence_or_clarify", state, result)

    return result
