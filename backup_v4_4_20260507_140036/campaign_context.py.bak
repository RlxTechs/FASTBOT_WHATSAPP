import io
import json
import re
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

from PIL import Image
from selenium.webdriver.common.by import By

BASE_DIR = Path(__file__).resolve().parent
CAMPAIGNS_PATH = BASE_DIR / "campaigns.json"
UNKNOWN_PATH = BASE_DIR / "unknown_campaigns.json"
CAPTURES_DIR = BASE_DIR / "campaign_captures"
CAPTURES_DIR.mkdir(exist_ok=True)

FACEBOOK_MARKERS = [
    "publicite de facebook",
    "publicité de facebook",
    "afficher les details",
    "afficher les détails",
    "salutation automatique",
    "comment pouvons nous vous aider",
    "comment pouvons-nous vous aider"
]

def load_json(path: Path, default: Any) -> Any:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def save_json(path: Path, data: Any):
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")

def normalize(text: str) -> str:
    import unicodedata
    text = str(text or "").lower()
    text = unicodedata.normalize("NFD", text)
    text = "".join(ch for ch in text if unicodedata.category(ch) != "Mn")
    text = re.sub(r"[^a-z0-9+\s'.:/-]", " ", text)
    return re.sub(r"\s+", " ", text).strip()

def campaigns_data() -> Dict[str, Any]:
    return load_json(CAMPAIGNS_PATH, {"version": 1, "match_threshold": 10, "campaigns": []})

def unknown_data() -> Dict[str, Any]:
    return load_json(UNKNOWN_PATH, {"unknown": {}})

def average_hash_from_png(png_bytes: bytes, hash_size: int = 8) -> str:
    img = Image.open(io.BytesIO(png_bytes)).convert("L")
    try:
        resample = Image.Resampling.LANCZOS
    except Exception:
        resample = Image.LANCZOS
    img = img.resize((hash_size, hash_size), resample)
    pixels = list(img.getdata())
    avg = sum(pixels) / len(pixels)
    bits = "".join("1" if p > avg else "0" for p in pixels)
    return hex(int(bits, 2))[2:].zfill(hash_size * hash_size // 4)

def hamming(a: str, b: str) -> int:
    try:
        x = int(a, 16) ^ int(b, 16)
        return bin(x).count("1")
    except Exception:
        return 999

def recent_bubbles(driver, limit: int = 24):
    bubbles = driver.find_elements(By.CSS_SELECTOR, "div.message-in, div.message-out")
    return bubbles[-limit:]

def is_facebook_ad_bubble(text: str) -> bool:
    t = normalize(text)
    return any(normalize(m) in t for m in FACEBOOK_MARKERS)

def find_facebook_ad_bubbles(driver, limit: int = 24):
    found = []
    for bubble in recent_bubbles(driver, limit):
        try:
            txt = bubble.text.strip()
        except Exception:
            txt = ""
        if is_facebook_ad_bubble(txt):
            found.append((bubble, txt))
    return found

def screenshot_element_png(el) -> bytes:
    try:
        png = el.screenshot_as_png
        if png and len(png) > 500:
            return png
    except Exception:
        pass
    return b""

def best_image_from_bubble(bubble) -> bytes:
    candidates = []
    try:
        imgs = bubble.find_elements(By.CSS_SELECTOR, "img")
    except Exception:
        imgs = []

    for img in imgs:
        try:
            size = img.size or {}
            w = int(size.get("width", 0))
            h = int(size.get("height", 0))

            # Les miniatures Facebook sont parfois petites, donc seuil bas.
            if w < 28 or h < 28:
                continue

            png = screenshot_element_png(img)
            if png:
                candidates.append((w * h, png))
        except Exception:
            continue

    if candidates:
        candidates.sort(key=lambda x: x[0], reverse=True)
        return candidates[0][1]

    return screenshot_element_png(bubble)

def find_campaign_by_hash(ahash: str) -> Optional[Dict[str, Any]]:
    data = campaigns_data()
    threshold = int(data.get("match_threshold", 10))

    best = None
    best_dist = 999

    for c in data.get("campaigns", []):
        for h in c.get("hashes", []) or []:
            dist = hamming(ahash, h)
            if dist < best_dist:
                best_dist = dist
                best = c

    if best and best_dist <= threshold:
        c = dict(best)
        c["_match_distance"] = best_dist
        c["_matched_hash"] = ahash
        return c

    return None

def find_campaign_by_text(text: str) -> Optional[Dict[str, Any]]:
    t = normalize(text)
    if not t:
        return None

    best = None
    best_score = 0

    for c in campaigns_data().get("campaigns", []):
        score = 0
        for kw in c.get("keywords", []) or []:
            kw_norm = normalize(kw)
            if kw_norm and kw_norm in t:
                score += 1
        if score > best_score:
            best_score = score
            best = c

    if best and best_score >= 2:
        c = dict(best)
        c["_match_text_score"] = best_score
        return c

    return None

def save_unknown_hash(ahash: str, png: bytes, chat_id: str, card_text: str):
    data = unknown_data()
    unknown = data.setdefault("unknown", {})

    if ahash not in unknown:
        img_path = CAPTURES_DIR / f"unknown_{ahash}.png"
        img_path.write_bytes(png)
        unknown[ahash] = {
            "hash": ahash,
            "image": str(img_path),
            "chat_example": chat_id,
            "card_text": card_text,
            "label_status": "waiting_label",
            "source": "facebook_ad_card",
            "note": "Ouvre cette image, puis lance campaign_admin.bat pour l'associer à une campagne."
        }
        save_json(UNKNOWN_PATH, data)

def campaign_state_patch(c: Dict[str, Any]) -> Dict[str, Any]:
    patch = {
        "campaign_id": c.get("id", ""),
        "campaign_label": c.get("label", ""),
        "campaign_category": c.get("category", ""),
        "campaign_intent": c.get("intent", ""),
        "campaign_product_id": c.get("product_id", ""),
        "campaign_product_query": c.get("product_query", ""),
        "last_category": c.get("category", "")
    }

    if c.get("product_id"):
        patch["last_product_id"] = c.get("product_id")

    return patch

def recent_text(driver, limit: int = 24) -> str:
    texts = []
    for b in recent_bubbles(driver, limit):
        try:
            t = b.text.strip()
            if t:
                texts.append(t)
        except Exception:
            pass
    return "\n".join(texts)

def detect_campaign_from_chat(driver, chat_id: str = "conversation") -> Optional[Dict[str, Any]]:
    # 1) Priorité : cartes “Publicité de Facebook”
    ad_cards = find_facebook_ad_bubbles(driver)

    for bubble, card_text in reversed(ad_cards):
        png = best_image_from_bubble(bubble)
        if not png:
            continue

        ahash = average_hash_from_png(png)
        campaign = find_campaign_by_hash(ahash)

        if campaign:
            return {
                "source": "facebook_ad_card_image",
                "hash": ahash,
                "id": campaign.get("id"),
                "label": campaign.get("label"),
                "campaign": campaign,
                "state_patch": campaign_state_patch(campaign)
            }

        # Si le hash est inconnu, on tente le texte autour de la carte.
        by_text = find_campaign_by_text(card_text)
        if by_text:
            return {
                "source": "facebook_ad_card_text",
                "hash": ahash,
                "id": by_text.get("id"),
                "label": by_text.get("label"),
                "campaign": by_text,
                "state_patch": campaign_state_patch(by_text)
            }

        save_unknown_hash(ahash, png, chat_id, card_text)

        return {
            "source": "facebook_ad_card_unknown",
            "unknown": True,
            "hash": ahash,
            "label": "Pub Facebook inconnue",
            "state_patch": {}
        }

    # 2) Secours : texte récent
    txt = recent_text(driver)
    by_text = find_campaign_by_text(txt)
    if by_text:
        return {
            "source": "recent_text",
            "id": by_text.get("id"),
            "label": by_text.get("label"),
            "campaign": by_text,
            "state_patch": campaign_state_patch(by_text)
        }

    return None
