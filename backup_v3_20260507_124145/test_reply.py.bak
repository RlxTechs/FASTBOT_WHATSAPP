from bot_core import generate_reply

CHAT_ID = "test_console"

print("Test rapide du cerveau bot V2.")
print("Il garde maintenant le contexte. Exemple : 'je veux un ordinateur' puis 'core i3'.")
print("Tape exit pour quitter.\n")

while True:
    msg = input("Client > ").strip()
    if msg.lower() in {"exit", "quit", "q"}:
        break

    result = generate_reply(msg, chat_id=CHAT_ID)
    print("\nIntent :", result["intent"])
    print("Confiance :", result["confidence"])
    print("Auto-safe :", result["safe_to_auto_send"])
    print("Réponse :")
    print(result["reply"])
    print("-" * 60)
