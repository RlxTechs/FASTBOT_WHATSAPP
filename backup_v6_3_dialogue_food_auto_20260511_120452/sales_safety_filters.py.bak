import json
import re
from pathlib import Path
from typing import Optional, Dict, Any

from bot_core import normalize, get_state

try:
    from app_paths import BASE_DIR
except Exception:
    BASE_DIR = Path(__file__).resolve().parent

SALES_CONFIG_PATH = BASE_DIR / "sales_config.json"

def load_json(path: Path, default: Any):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def cfg():
    return load_json(SALES_CONFIG_PATH, {})

def state_has_context(chat_id: str) -> bool:
    st = get_state(chat_id)
    return bool(st.get("campaign_id") or st.get("campaign_category") or st.get("last_category") or st.get("last_product_family"))

def is_forward_marker_only(message: str) -> bool:
    m = normalize(message)
    return m in {
        "transfere", "transféré", "message transfere", "message transféré",
        "forwarded", "fwd"
    }

def is_ack_only(message: str) -> bool:
    m = normalize(message)

    if not m:
        return True

    if len(m.split()) > 5:
        return False

    ack_exact = {
        "d accord", "daccord", "dac", "ok", "ok merci", "merci",
        "merci beaucoup", "merci bien", "ca marche", "ça marche",
        "c est bon", "cest bon", "bien recu", "bien reçu", "recu",
        "reçu", "note", "noté", "parfait", "cool", "svp", "stp",
        "s il vous plait", "s il vous plaît", "s'il vous plait",
        "s'il vous plaît", "sil vous plait", "sil vous plaît"
    }

    if m in ack_exact:
        return True

    allowed_words = {
        "d", "accord", "daccord", "ok", "merci", "beaucoup", "bien",
        "recu", "reçu", "note", "noté", "parfait", "cool", "marche",
        "ca", "ça", "svp", "stp", "s", "il", "vous", "plait", "plaît"
    }

    words = set(m.split())
    return bool(words) and words.issubset(allowed_words)

def is_simple_greeting_only(message: str) -> bool:
    m = normalize(message)
    return m in {
        "cc", "coucou", "salut", "slt", "bonjour", "bonsoir",
        "bjr", "bsr", "hello", "allo"
    }

def greeting_reply() -> str:
    return (
        "Bonjour 👋\n"
        "Vous cherchez quel article ou quel service exactement ?\n\n"
        "Envoyez le nom du produit, le plat voulu, ou une capture de la pub, et je vous réponds rapidement."
    )

def is_job_request(message: str) -> bool:
    m = normalize(message)
    patterns = [
        r"\bemploi\b", r"\btravail\b", r"\bjob\b", r"\bposte\b",
        r"\bstage\b", r"\bstagiaire\b", r"\bcv\b", r"\brecrut\w*\b",
        r"\bembauch\w*\b", r"\bemploye\w*\b", r"\bemployé\w*\b",
        r"\bpersonnel\b", r"\bvendeur\b", r"\bvendeuse\b",
        r"\bserveur\b", r"\bserveuse\b", r"\bchauffeur\b", r"\blivreur\b",
        r"\bvous cherchez.*employ", r"\bcherchez.*employ",
        r"\bavez vous besoin.*employ", r"\bbesoin.*employ",
        r"\bje cherche.*travail", r"\bje cherche.*emploi",
        r"\bje veux travailler", r"\btravailler chez vous"
    ]
    return any(re.search(p, m) for p in patterns)

def not_hiring_reply() -> str:
    return cfg().get("hr", {}).get(
        "not_hiring_reply",
        "Bonjour 🙏 Désolé, nous ne recherchons personne pour le moment.\n"
        "Nous n’avons pas de besoin en employés actuellement.\n\n"
        "Merci pour votre compréhension."
    )

def classify_pre_reply(combined_message: str, latest_message: str, chat_id: str = "default") -> Optional[Dict]:
    combined_norm = normalize(combined_message)
    latest_norm = normalize(latest_message)
    only_latest = combined_norm == latest_norm

    # “Transféré” seul n’est pas une demande client.
    if only_latest and is_forward_marker_only(latest_message):
        return {
            "reply": "",
            "confidence": 0.0,
            "intent": "no_reply_forward_marker",
            "safe_to_auto_send": False,
            "debug": {"source": "sales_safety_filters", "reason": "forward marker only"}
        }

    # “ok”, “d’accord”, “svp”, “merci” seuls => silence.
    if only_latest and is_ack_only(latest_message):
        return {
            "reply": "",
            "confidence": 0.0,
            "intent": "no_reply_acknowledgement",
            "safe_to_auto_send": False,
            "debug": {"source": "sales_safety_filters", "reason": "acknowledgement only"}
        }

    # “Cc” / “Bonjour” sans contexte => réponse courte, pas de moteur produit.
    if only_latest and is_simple_greeting_only(latest_message) and not state_has_context(chat_id):
        return {
            "reply": greeting_reply(),
            "confidence": 0.90,
            "intent": "simple_greeting_no_context",
            "safe_to_auto_send": True,
            "debug": {"source": "sales_safety_filters", "reason": "simple greeting without context"}
        }

    if is_job_request(combined_message):
        return {
            "reply": not_hiring_reply(),
            "confidence": 0.96,
            "intent": "hr_not_hiring",
            "safe_to_auto_send": True,
            "debug": {"source": "sales_safety_filters", "reason": "employment request"}
        }

    return None
