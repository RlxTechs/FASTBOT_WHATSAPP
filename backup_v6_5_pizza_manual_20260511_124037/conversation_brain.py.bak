import json
from pathlib import Path
from typing import Dict, Any, Optional

from bot_core import normalize, get_state
from sales_orchestrator import generate_sales_reply
from product_sales_engine import try_product_sales_reply
from food_order_guard import try_food_order_guard
from food_sales_engine import try_food_sales_reply

try:
    from app_paths import BASE_DIR
except Exception:
    BASE_DIR = Path(__file__).resolve().parent

SALES_CONFIG_PATH = BASE_DIR / "sales_config.json"

def load_json(path: Path, default: Any):
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def cfg():
    return load_json(SALES_CONFIG_PATH, {})

def food_menu_reply(prefix: str = "") -> str:
    food = cfg().get("food", {})
    lines = []

    if prefix:
        lines.append(prefix)
        lines.append("")

    lines.append(food.get("brand_line", "Nos plats sont spéciaux 🔥🍗🍟🍲🛒"))
    lines.append(food.get("delivery_only_line", "On fait uniquement par livraison. 🚚"))
    lines.append("")
    lines.append("Voici le menu disponible :")

    items = food.get("items", [])
    if items:
        for item in items:
            lines.append(f"• {item.get('name')} — {item.get('price')}")
    else:
        lines.extend([
            "• Portion de frites — 1.000 F",
            "• Portion d’alloco / bananes frites — 1.000 F",
            "• Alloco poulet — 2.000 F",
            "• Chawarma poulet — 2.500 F",
            "• Riz thieb poulet — 2.500 F",
            "• Hamburger — 3.000 F / 4.000 F"
        ])

    lines.append("")
    lines.append("Livraison uniquement sur Brazzaville selon votre zone.")
    lines.append("Pour commander, envoyez le plat choisi + votre quartier + votre numéro + adresse précise.")

    return "\n".join(lines)

def asks_food_context(message: str) -> bool:
    m = normalize(message)
    checks = [
        "je parle de la nourriture",
        "nourriture",
        "vos prix m ont attire",
        "vos prix mon beaucoup attire",
        "tu as faim",
        "menu",
        "plat",
        "restaurant",
        "alloco",
        "chawarma",
        "hamburger",
        "riz thieb",
        "yassa"
    ]
    return any(x in m for x in checks)

def asks_birthday_cake(message: str) -> bool:
    m = normalize(message)
    checks = [
        "gateau anniversaire",
        "gâteau anniversaire",
        "gateaux anniversaire",
        "gâteaux anniversaire",
        "gateau d anniversaire",
        "gâteau d anniversaire",
        "gateaux d anniversaire",
        "gâteaux d anniversaire",
        "cake anniversaire",
        "anniversaire"
    ]
    return any(x in m for x in checks)

def birthday_cake_reply() -> str:
    return (
        "Oui, on en fait aussi 🎂✨\n\n"
        "Nous réalisons des gâteaux d’anniversaire sur commande, selon le thème, la taille et votre budget.\n\n"
        "Envoyez-moi simplement :\n"
        "1) le nombre de personnes\n"
        "2) la date prévue\n"
        "3) le thème ou les couleurs\n"
        "4) votre budget si vous en avez un\n\n"
        "Je peux aussi vous montrer quelques modèles pour vous aider à choisir 👇"
    )

def is_generic_fb_more_info(message: str) -> bool:
    m = normalize(message)
    checks = [
        "puis je en savoir plus",
        "je peux en savoir plus",
        "en savoir plus",
        "plus a ce sujet",
        "plus à ce sujet",
        "a ce sujet",
        "ce sujet"
    ]
    return any(x in m for x in checks)

def seller_fallback() -> str:
    return cfg().get("non_food", {}).get(
        "facebook_no_context_seller_fallback",
        "Bonjour 👋 Oui bien sûr.\nDites-moi ce qui vous intéresse exactement : nourriture, TV, iPhone, informatique, électroménager, énergie ou papeterie ?"
    )

def generate_human_sales_reply(message: str, chat_id: str = "default") -> Dict[str, Any]:
    state = get_state(chat_id)

    # 1) Garde nourriture runtime : commande, zone, délai, quantité, correction.
    food_guard = try_food_order_guard(message, message.split("\n")[-1], chat_id)
    if food_guard:
        return food_guard

    # 2) Nourriture précise en priorité si contexte menu ou message food.
    food_direct = try_food_sales_reply(message, chat_id)
    if food_direct:
        return food_direct

    # 2) Produits officiels products.json : iPhone, XR, 12 Pro Max, imprimante, laptop, TV...
    product = try_product_sales_reply(message, chat_id)
    if product:
        return product

    # 2) Gâteaux d’anniversaire.
    if asks_birthday_cake(message):
        return {
            "reply": birthday_cake_reply(),
            "confidence": 0.96,
            "intent": "birthday_cakes",
            "safe_to_auto_send": True,
            "_state_patch": {
                "last_category": "food",
                "last_product_family": "cakes",
                "last_product_query": "Gâteaux d’anniversaire"
            },
            "debug": {"source": "conversation_brain_cakes"}
        }

    # 3) Le client corrige le contexte : “je parle de la nourriture”.
    if asks_food_context(message):
        return {
            "reply": food_menu_reply("Ah d’accord, parfait 😊 Vous parlez de la nourriture. Voici nos prix :"),
            "confidence": 0.96,
            "intent": "food_context_confirmed_by_client",
            "safe_to_auto_send": True,
            "_state_patch": {
                "last_category": "food",
                "campaign_category": "food",
                "last_product_family": "food",
                "last_product_query": "menu nourriture"
            },
            "debug": {"source": "conversation_brain_food_context"}
        }

    # 4) Fallback Facebook seulement si aucun produit/contexte n’a été compris.
    if is_generic_fb_more_info(message) and not state.get("campaign_id") and not state.get("last_category"):
        return {
            "reply": seller_fallback(),
            "confidence": 0.90,
            "intent": "seller_fallback_no_context",
            "safe_to_auto_send": True,
            "debug": {"source": "conversation_brain_fallback"}
        }

    # 5) Ancien orchestrateur.
    return generate_sales_reply(message, chat_id)
