    {
      "id": "greeting_more_info",
      "label": "Salutation + demande d'information Facebook",
      "priority": 98,
      "threshold": 4,
      "safe_to_auto_send": true,
      "template": "greeting_more_info",
      "patterns": [
        "\\bpuis je en savoir plus\\b",
        "\\bje peux en savoir plus\\b",
        "\\bplus a ce sujet\\b",
        "\\bplus d info\\b",
        "\\bplus d infos\\b",
        "\\ben savoir plus\\b",
        "\\bbonjour.*savoir plus\\b",
        "\\bbonjour.*ce sujet\\b"
      ],
      "keywords": [
        "savoir plus",
        "ce sujet",
        "infos",
        "information",
        "pub",
        "facebook"
      ],
      "examples": [
        "Bonjour ! Puis-je en savoir plus à ce sujet ?",
        "Bonjour je veux en savoir plus",
        "Je peux avoir plus d'informations ?",
        "C'est par rapport à la pub Facebook"
      ]
    },
