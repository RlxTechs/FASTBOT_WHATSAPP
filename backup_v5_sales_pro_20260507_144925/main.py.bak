import json
import time
from datetime import datetime
from pathlib import Path

import pyperclip
from selenium.common.exceptions import StaleElementReferenceException, NoSuchElementException
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys

from chrome_control import attach_driver, ensure_whatsapp_tab, wait_for_whatsapp_ready
from bot_core import get_state, set_state
from smart_reply import generate_smart_reply
from campaign_context import detect_campaign_from_chat

BASE_DIR = Path(__file__).resolve().parent
LOG_PATH = BASE_DIR / "conversations_log.jsonl"
SETTINGS_PATH = BASE_DIR / "settings.json"

def load_settings():
    try:
        return json.loads(SETTINGS_PATH.read_text(encoding="utf-8-sig"))
    except Exception:
        return {}

def log_event(data):
    data["time"] = datetime.now().isoformat(timespec="seconds")
    with LOG_PATH.open("a", encoding="utf-8") as f:
        f.write(json.dumps(data, ensure_ascii=False) + "\n")

def get_chat_title(driver):
    try:
        headers = driver.find_elements(By.CSS_SELECTOR, "header span[dir='auto']")
        for h in headers:
            txt = h.text.strip()
            if txt and len(txt) < 90:
                return txt
    except Exception:
        pass
    return "conversation_ouverte"

def clean_message_text(text):
    lines = []
    for line in (text or "").splitlines():
        t = line.strip()
        if not t:
            continue
        if len(t) <= 5 and ":" in t and any(ch.isdigit() for ch in t):
            continue
        if t.lower() in {"modifié", "edited"}:
            continue
        lines.append(t)
    return "\n".join(lines).strip()

def read_last_incoming_message(driver):
    try:
        incoming = driver.find_elements(By.CSS_SELECTOR, "div.message-in")
        if not incoming:
            return ""

        last = incoming[-1]
        spans = last.find_elements(By.CSS_SELECTOR, "span.selectable-text.copyable-text")
        parts = []

        for s in spans:
            try:
                tx = s.text.strip()
                if tx:
                    parts.append(tx)
            except StaleElementReferenceException:
                continue

        if parts:
            return clean_message_text("\n".join(parts))

        return clean_message_text(last.text)
    except Exception:
        return ""

def find_message_box(driver):
    selectors = [
        "footer div[contenteditable='true'][role='textbox']",
        "footer div[contenteditable='true']",
        "div[contenteditable='true'][role='textbox']"
    ]

    for css in selectors:
        try:
            els = driver.find_elements(By.CSS_SELECTOR, css)
            for el in els:
                if el.is_displayed():
                    return el
        except Exception:
            continue

    try:
        return driver.find_element(By.XPATH, "//footer//div[@contenteditable='true']")
    except NoSuchElementException:
        return None

def get_box_text(box):
    try:
        return (box.text or "").strip()
    except Exception:
        return ""

def paste_reply(driver, reply_text, send=False):
    settings = load_settings()
    box = find_message_box(driver)
    if not box:
        return False, "zone_message_introuvable"

    current_draft = get_box_text(box)
    if settings.get("skip_if_message_box_not_empty", True) and current_draft:
        return False, "brouillon_deja_present_non_ecrase"

    box.click()
    time.sleep(0.1)
    box.send_keys(Keys.CONTROL, "a")
    time.sleep(0.05)
    box.send_keys(Keys.BACKSPACE)
    time.sleep(0.05)

    pyperclip.copy(reply_text)
    box.send_keys(Keys.CONTROL, "v")
    time.sleep(float(settings.get("auto_send_delay_seconds", 0.8)))

    if send:
        box.send_keys(Keys.ENTER)

    return True, "envoye" if send else "colle"

def mandatory_campaign_precheck(driver, chat_title):
    """
    Cette fonction est obligatoire AVANT toute réponse.
    Si une carte Facebook inconnue est détectée, le bot bloque la réponse.
    """
    state_before = get_state(chat_title)

    # Si la conversation a déjà un contexte connu, on ne rescane pas inutilement.
    if state_before.get("campaign_id") and not state_before.get("needs_campaign_label"):
        return "known_context"

    camp = detect_campaign_from_chat(driver, chat_title)

    if not camp:
        print("[PRECHECK] Aucune carte Facebook détectée ou aucun contexte utile.")
        return "no_campaign_card"

    if camp.get("unknown"):
        h = camp.get("hash", "")
        print("")
        print("⚠️ PUB FACEBOOK INCONNUE DÉTECTÉE AVANT RÉPONSE")
        print("Conversation :", chat_title)
        print("Hash :", h)
        print("Ouvre admin_campaign_gui.bat pour voir la miniature et l'attribuer.")
        print("Le bot NE répondra PAS au client tant que cette pub n’est pas classée.")
        print("")

        set_state(chat_title, {
            "needs_campaign_label": True,
            "unknown_campaign_hash": h,
            "unknown_campaign_source": camp.get("source", "facebook_ad_card_unknown"),
            "unknown_campaign_image": "campaign_captures/unknown_" + str(h) + ".png"
        })
        return "unknown_campaign_blocked"

    patch = camp.get("state_patch", {})
    patch["needs_campaign_label"] = False
    set_state(chat_title, patch)
    print("[PRECHECK] Contexte pub détecté :", camp.get("label"), "| source :", camp.get("source"))
    return "campaign_detected"

def main():
    s = load_settings()
    send_auto = bool(s.get("send_automatically", False))
    min_conf = float(s.get("confidence_required", 0.88))
    safe_only = bool(s.get("auto_send_only_safe", True))

    print("=" * 82)
    print("OCG / BZ STORE — Assistant WhatsApp vendeur V4.5")
    print("=" * 82)
    print("Mode :", "AUTO sécurisé" if send_auto else "SÉCURISÉ : colle sans envoyer")
    print("NOUVEAU : pré-analyse obligatoire des cartes Facebook AVANT toute réponse.")
    print("Si pub inconnue : aucune réponse envoyée, attribution via admin graphique.")
    print("=" * 82)

    driver = attach_driver()
    ensure_whatsapp_tab(driver)
    wait_for_whatsapp_ready(driver)

    print("")
    print("Ouvre une conversation client dans WhatsApp Web.")
    print("CTRL+C pour arrêter.")
    print("")

    last_key = ""

    while True:
        try:
            chat_title = get_chat_title(driver)

            # 1) Précheck obligatoire AVANT lecture/réponse
            precheck = mandatory_campaign_precheck(driver, chat_title)

            state = get_state(chat_title)
            if state.get("needs_campaign_label"):
                # On bloque complètement : pas de réponse vague, pas d'auto-send.
                time.sleep(float(s.get("poll_seconds", 2.0)))
                continue

            # 2) Maintenant seulement, on lit le dernier message client
            last_msg = read_last_incoming_message(driver)

            if last_msg:
                key = f"{chat_title}::{last_msg}"

                if key != last_key:
                    result = generate_smart_reply(last_msg, chat_id=chat_title)
                    reply = result.get("reply", "").strip()
                    conf = float(result.get("confidence", 0))
                    intent = result.get("intent", "")
                    safe = bool(result.get("safe_to_auto_send", False))

                    should_send = send_auto and conf >= min_conf
                    if safe_only:
                        should_send = should_send and safe

                    print("-" * 82)
                    print("Conversation :", chat_title)
                    print("Précheck :", precheck)
                    print("Message client :", last_msg)
                    print("Intent :", intent, "| confiance :", conf, "| safe :", safe)
                    print("Auto-send :", should_send)

                    if reply and conf >= 0.35:
                        ok, action = paste_reply(driver, reply, send=should_send)
                        print("Action :", action)
                        print("Réponse :")
                        print(reply)

                        log_event({
                            "chat": chat_title,
                            "precheck": precheck,
                            "client_message": last_msg,
                            "reply": reply,
                            "intent": intent,
                            "confidence": conf,
                            "safe": safe,
                            "auto_sent": should_send and ok,
                            "pasted": ok,
                            "action": action
                        })
                    else:
                        print("Aucune réponse fiable ou réponse bloquée.")
                        log_event({
                            "chat": chat_title,
                            "precheck": precheck,
                            "client_message": last_msg,
                            "reply": "",
                            "intent": intent,
                            "confidence": conf,
                            "safe": safe,
                            "auto_sent": False,
                            "pasted": False,
                            "action": "no_reply_or_blocked"
                        })

                    last_key = key

            time.sleep(float(s.get("poll_seconds", 2.0)))

        except KeyboardInterrupt:
            print("\nArrêt demandé.")
            break
        except Exception as e:
            print("Erreur capturée, le bot continue :", repr(e))
            log_event({"error": repr(e), "where": "main_loop"})
            time.sleep(3)

if __name__ == "__main__":
    main()
