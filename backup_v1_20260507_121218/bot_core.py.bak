import json
import re
import unicodedata
from pathlib import Path
from typing import Any, Dict, List, Tuple

BASE_DIR = Path(__file__).resolve().parent
PRODUCTS_PATH = BASE_DIR / "products.json"
FOOD_MENU_PATH = BASE_DIR / "food_menu.json"
SETTINGS_PATH = BASE_DIR / "settings.json"

def load_json(path: Path, default: Any) -> Any:
    try:
        if path.exists():
            return json.loads(path.read_text(encoding="utf-8-sig"))
    except Exception:
        return default
    return default

def normalize(text: str) -> str:
    text = str(text or "").lower()
    text = unicodedata.normalize("NFD", text)
    text = "".join(ch for ch in text if unicodedata.category(ch) != "Mn")
    text = text.replace("’", "'").replace("`", "'")
    text = re.sub(r"[^a-z0-9+\s'.:/-]", " ", text)
    text = re.sub(r"\s+", " ", text).strip()
    return text

def price(value: Any) -> str:
    try:
        n = int(float(value))
    except Exception:
        return "prix à confirmer"
    if n <= 0:
        return "prix à confirmer"
    return f"{n:,}".replace(",", ".") + " F"

def load_settings() -> Dict[str, Any]:
    return load_json(SETTINGS_PATH, {})

def load_catalog() -> Dict[str, Any]:
    data = load_json(PRODUCTS_PATH, {"products": [], "categories": [], "meta": {}})
    if isinstance(data, list):
        return {"products": data, "categories": [], "meta": {}}
    return data

def load_food_menu() -> Dict[str, Any]:
    return load_json(FOOD_MENU_PATH, {"items": []})

def all_products() -> List[Dict[str, Any]]:
    data = load_catalog()
    return data.get("products", []) if isinstance(data, dict) else []

def product_words(product: Dict[str, Any]) -> str:
    parts = [
        product.get("id", ""),
        product.get("title", ""),
        product.get("subtitle", ""),
        product.get("tag", ""),
        product.get("categoryId", ""),
        product.get("description", ""),
    ]
    for v in product.get("variants", []) or []:
        parts.append(v.get("name", ""))
    return normalize(" ".join(str(x) for x in parts if x))

def score_product(msg_norm: str, product: Dict[str, Any]) -> int:
    hay = product_words(product)
    title = normalize(product.get("title", ""))
    pid = normalize(product.get("id", ""))

    score = 0
    for token in set(msg_norm.split()):
        if len(token) < 2:
            continue
        if token in hay:
            score += 1
        if token in title or token in pid:
            score += 2

    if "iphone" in msg_norm and "iphone" in hay:
        score += 8
    if any(x in msg_norm for x in ["tv", "tele", "television", "smart"]) and product.get("categoryId") == "tv":
        score += 8
    if any(x in msg_norm for x in ["frigo", "refrigerateur"]) and product.get("categoryId") == "refrigerateur":
        score += 8
    if any(x in msg_norm for x in ["congelateur", "congelo"]) and product.get("categoryId") == "congelateur":
        score += 8
    if any(x in msg_norm for x in ["split", "clim", "climatiseur"]) and product.get("categoryId") == "split":
        score += 8
    if any(x in msg_norm for x in ["laptop", "ordinateur", "pc"]) and "laptop" in hay:
        score += 8
    if any(x in msg_norm for x in ["groupe", "electrogene", "kva"]) and "groupe" in hay:
        score += 8
    return score

def extract_inches(msg_norm: str) -> str:
    m = re.search(r"\b(32|43|50|55|65|75)\s*(pouces?|p|inch|inches|')?\b", msg_norm)
    return m.group(1) if m else ""

def extract_kva(msg_norm: str) -> str:
    m = re.search(r"\b(1|5|7|8|9|10|15|20|30|50|100|500)\s*k\s*v\s*a\b", msg_norm)
    if m:
        return m.group(1)
    m = re.search(r"\b(1|5|7|8|9|10|15|20|30|50|100|500)\s*kva\b", msg_norm)
    return m.group(1) if m else ""

def is_greeting(msg_norm: str) -> bool:
    return bool(re.fullmatch(r"(bonjour|bonsoir|salut|bjr|bsr|hello|allo|wesh|cc|coucou|slt|yo)[\s!.]*", msg_norm))

def is_thanks(msg_norm: str) -> bool:
    return any(x in msg_norm for x in ["merci", "thanks", "ok merci", "daccord merci"])

def wants_delivery(msg_norm: str) -> bool:
    return any(x in msg_norm for x in ["livraison", "livrer", "livrez", "transport", "deplacement", "frais"])

def wants_city_or_location(msg_norm: str) -> bool:
    return any(x in msg_norm for x in ["ville", "vous etes ou", "vous etes dans quelle ville", "adresse", "localisation", "localiser", "boutique ou"])

def wants_contact(msg_norm: str) -> bool:
    return any(x in msg_norm for x in ["numero", "telephone", "tel", "appel", "whatsapp", "contact"])

def wants_menu(msg_norm: str) -> bool:
    return any(x in msg_norm for x in ["menu", "nourriture", "manger", "plat", "riz", "alloco", "banane", "chawarma", "yassa", "thieb", "saka"])

def is_vague_price(msg_norm: str) -> bool:
    vague = ["prix", "combien", "cest combien", "c'est combien", "dispo", "disponible", "ca coute", "ça coute"]
    return any(v in msg_norm for v in vague) and len(msg_norm.split()) <= 4

def delivery_reply(settings: Dict[str, Any]) -> str:
    city = settings.get("city", "Brazzaville")
    return (
        f"Oui, livraison possible à {city}. 🚚\n"
        "Pour Moungali et les environs, la livraison peut commencer à 500 F.\n"
        "Si vous êtes plus loin, ça commence souvent à partir de 800 F selon la zone.\n\n"
        "Envoyez votre quartier + adresse précise, je confirme le montant exact."
    )

def city_reply(settings: Dict[str, Any]) -> str:
    city = settings.get("city", "Brazzaville")
    business = settings.get("business_name", "O'CG")
    return (
        f"Nous sommes à {city}. 📍\n"
        f"{business} livre dans plusieurs zones selon la distance.\n"
        "Envoyez votre quartier et l’article voulu, je vous confirme rapidement."
    )

def contact_reply(settings: Dict[str, Any]) -> str:
    wa = settings.get("whatsapp", "+242050541963")
    phone = settings.get("phone", "+242066518669")
    return f"Vous pouvez nous écrire sur WhatsApp : {wa}\nOu appeler : {phone}"

def menu_reply() -> str:
    menu = load_food_menu()
    items = menu.get("items", [])
    if not items:
        return "Le menu est disponible. Vous voulez quel plat exactement ?"
    lines = ["Voici le menu disponible 🍽️"]
    for it in items:
        name = it.get("name", "Article")
        p = it.get("price")
        note = it.get("note", "")
        if isinstance(p, list):
            p_txt = " / ".join(price(x) for x in p)
        else:
            p_txt = price(p)
        line = f"• {name} — {p_txt}"
        if note:
            line += f" ({note})"
        lines.append(line)
    lines.append("\nLivraison possible. Envoyez votre quartier + numéro.")
    return "\n".join(lines)

def variant_match(msg_norm: str, product: Dict[str, Any]):
    variants = product.get("variants", []) or []
    if not variants:
        return None

    best = None
    best_score = 0
    for v in variants:
        name = normalize(v.get("name", ""))
        sc = 0
        for token in set(msg_norm.split()):
            if len(token) >= 2 and token in name:
                sc += 1

        if "pro max" in msg_norm and "pro max" in name:
            sc += 8
        elif "pro" in msg_norm and "pro" in name and "pro max" not in msg_norm:
            sc += 5
        if "plus" in msg_norm and "plus" in name:
            sc += 5
        if "max" in msg_norm and "max" in name:
            sc += 4

        inches = extract_inches(msg_norm)
        if inches and inches in name:
            sc += 8

        kva = extract_kva(msg_norm)
        if kva and kva in name and "kva" in name:
            sc += 8

        if sc > best_score:
            best_score = sc
            best = v

    return best if best_score >= 3 else None

def tv_size_reply(msg_norm: str, settings: Dict[str, Any]):
    inches = extract_inches(msg_norm)
    if not inches:
        return None
    if not any(x in msg_norm for x in ["tv", "tele", "television", "smart"]):
        return None

    results = []
    for p in all_products():
        if p.get("categoryId") != "tv":
            continue
        brand_title = p.get("title", "TV").replace("TV SMART", "").replace("TV Smart", "").strip()
        if not brand_title or brand_title.upper() == "TV":
            brand_title = p.get("subtitle", "TV").replace("•", "").strip() or "East Point"

        for v in p.get("variants", []) or []:
            vname = v.get("name", "")
            if inches in normalize(vname):
                results.append((brand_title, vname, v.get("price", 0)))

    if not results:
        return None

    lines = [f"Oui, voici les prix TV {inches} pouces disponibles :"]
    for brand, vname, p in sorted(results, key=lambda x: int(x[2] or 0)):
        lines.append(f"• {brand.title()} — {price(p)}")
    lines.append("\nVous voulez quelle marque ? Livraison possible à Brazzaville selon votre zone.")
    return "\n".join(lines)

def product_reply(msg: str, settings: Dict[str, Any]) -> Tuple[str, float, str]:
    msg_norm = normalize(msg)

    tv = tv_size_reply(msg_norm, settings)
    if tv:
        return tv, 0.95, "product_tv_size"

    products = all_products()
    scored = sorted([(score_product(msg_norm, p), p) for p in products], key=lambda x: x[0], reverse=True)
    scored = [(s, p) for s, p in scored if s > 0]

    if not scored or scored[0][0] < 5:
        return (
            "Je peux vous aider. Vous cherchez quel article exactement ?\n"
            "Exemples : TV 32 pouces, iPhone 13 Pro Max, laptop HP, frigo, congélateur, groupe électrogène, imprimante, nourriture."
        ), 0.35, "clarify_product"

    top_score, product = scored[0]
    title = product.get("title", "Produit")
    availability = product.get("availability", "Disponible")
    variants = product.get("variants", []) or []
    matched_variant = variant_match(msg_norm, product)

    if matched_variant:
        reply = f"{title} — {matched_variant.get('name')}: {price(matched_variant.get('price'))}.\n"
        reply += f"Disponibilité : {availability}.\n"
        reply += "Livraison possible à Brazzaville selon votre zone."
        return reply, 0.92, "product_variant"

    if variants:
        lines = [f"{title} est disponible avec plusieurs choix :"]
        for v in variants[:8]:
            lines.append(f"• {v.get('name')} — {price(v.get('price'))}")
        if len(variants) > 8:
            lines.append("• ...")
        lines.append("\nDites-moi le modèle exact que vous voulez.")
        return "\n".join(lines), 0.82, "product_variants_list"

    base = product.get("basePrice", 0)
    reply = f"{title} — {price(base)}.\nDisponibilité : {availability}."
    desc = product.get("description", "")
    if desc:
        clean_desc = " ".join(str(desc).splitlines()).strip()
        if clean_desc:
            reply += f"\n{clean_desc[:180]}"
    reply += "\nLivraison possible à Brazzaville selon votre zone."
    return reply, 0.86, "product_single"

def generate_reply(msg: str) -> Dict[str, Any]:
    settings = load_settings()
    msg_norm = normalize(msg)

    if not msg_norm:
        return {"reply": "", "confidence": 0.0, "intent": "empty", "safe_to_auto_send": False}

    if is_greeting(msg_norm):
        return {
            "reply": "Bonjour 👋 Bienvenue. Vous cherchez quel article ou service ? Vous pouvez écrire par exemple : TV 32, iPhone 13 Pro Max, frigo, laptop HP, nourriture, livraison.",
            "confidence": 0.92,
            "intent": "greeting",
            "safe_to_auto_send": True,
        }

    if is_thanks(msg_norm):
        return {
            "reply": "Avec plaisir 🙏 Si vous voulez commander, envoyez l’article + votre quartier + votre numéro.",
            "confidence": 0.9,
            "intent": "thanks",
            "safe_to_auto_send": True,
        }

    if wants_delivery(msg_norm):
        return {"reply": delivery_reply(settings), "confidence": 0.9, "intent": "delivery", "safe_to_auto_send": True}

    if wants_city_or_location(msg_norm):
        return {"reply": city_reply(settings), "confidence": 0.88, "intent": "city_location", "safe_to_auto_send": True}

    if wants_contact(msg_norm):
        return {"reply": contact_reply(settings), "confidence": 0.9, "intent": "contact", "safe_to_auto_send": True}

    if wants_menu(msg_norm):
        return {"reply": menu_reply(), "confidence": 0.86, "intent": "food_menu", "safe_to_auto_send": True}

    if is_vague_price(msg_norm):
        return {
            "reply": "Vous parlez de quel article exactement ? Envoyez le nom du produit ou une capture de la pub, et je vous donne le prix.",
            "confidence": 0.8,
            "intent": "vague_price",
            "safe_to_auto_send": True,
        }

    reply, conf, intent = product_reply(msg, settings)
    return {
        "reply": reply,
        "confidence": conf,
        "intent": intent,
        "safe_to_auto_send": conf >= 0.85 and intent in {"product_single", "product_variant", "product_tv_size", "delivery", "contact", "city_location", "greeting", "thanks"},
    }

if __name__ == "__main__":
    import sys
    message = " ".join(sys.argv[1:]) or input("Message client: ")
    print(json.dumps(generate_reply(message), ensure_ascii=False, indent=2))
