from typing import Dict

from bot_core import (
    generate_reply,
    get_state,
    find_product_by_id,
    price,
    normalize
)

from intent_bank import (
    try_intent_bank_reply,
    should_return_bank_before_product,
    record_unknown_message
)

def is_greeting(msg_norm: str) -> bool:
    return msg_norm in {
        "bonjour", "bonsoir", "salut", "bjr", "bsr", "hello", "allo", "slt", "cc"
    }

def is_vague_context_message(msg_norm: str) -> bool:
    vague_words = [
        "prix", "combien", "cest combien", "c est combien", "dispo", "disponible",
        "ca coute", "je veux", "interesse", "intéressé", "interesser", "c est disponible",
        "oui", "ok", "comment", "infos", "info", "je peux en savoir plus", "savoir plus",
        "plus a ce sujet", "plus à ce sujet", "bonjour puis je en savoir plus"
    ]

    if any(w in msg_norm for w in vague_words) and len(msg_norm.split()) <= 12:
        return True

    return False

def unknown_campaign_admin_reply(state: Dict) -> Dict:
    h = state.get("unknown_campaign_hash", "")
    img = state.get("unknown_campaign_image", "")

    return {
        "reply": "",
        "confidence": 0.0,
        "intent": "unknown_facebook_campaign_waiting_admin",
        "safe_to_auto_send": False,
        "debug": {
            "blocked_reason": "Facebook ad card detected but campaign is not labeled yet",
            "unknown_hash": h,
            "unknown_image": img,
            "admin_action": "Run campaign_admin.bat and label the image"
        }
    }

def product_context_reply(state: Dict, chat_id: str) -> str:
    label = state.get("campaign_label") or "la pub"
    product_id = state.get("campaign_product_id") or state.get("last_product_id")

    if product_id:
        p = find_product_by_id(product_id)
        if p:
            variants = p.get("variants", []) or []
            title = p.get("title", "cet article")
            availability = p.get("availability", "Disponible")

            if variants:
                lines = [f"Bonjour 👋 Vous venez sûrement de la {label}. Voici les options disponibles :"]
                for v in variants[:10]:
                    lines.append(f"• {v.get('name')} — {price(v.get('price'))}")
                lines.append(f"\nDisponibilité : {availability}.")
                lines.append("Envoyez le modèle exact + votre quartier pour confirmer la livraison.")
                return "\n".join(lines)

            return (
                f"Bonjour 👋 Vous venez sûrement de la {label}.\n"
                f"{title} — {price(p.get('basePrice', 0))}.\n"
                f"Disponibilité : {availability}.\n"
                "Envoyez votre quartier pour confirmer la livraison."
            )

    return ""

def category_context_reply(state: Dict, chat_id: str) -> str:
    label = state.get("campaign_label") or "la pub"
    category = state.get("campaign_category") or state.get("last_category") or ""
    query = state.get("campaign_product_query") or ""

    if category == "food":
        base = generate_reply("menu", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. 🍽️\n\n{base}"

    if category == "tv":
        base = generate_reply("tv", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. 📺\n\n{base}"

    if category == "energie":
        base = generate_reply(query or "groupe electrogene", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. ⚡\n\n{base}"

    if category == "refrigerateur":
        base = generate_reply(query or "refrigerateur", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. 🧊\n\n{base}"

    if category == "congelateur":
        base = generate_reply(query or "congelateur", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. 🧊\n\n{base}"

    if category == "split":
        base = generate_reply(query or "climatiseur split", chat_id=chat_id).get("reply", "")
        return f"Bonjour 👋 Vous venez sûrement de la {label}. ❄️\n\n{base}"

    if category == "iphones":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 📱\n"
            "Nous avons plusieurs séries iPhone disponibles.\n"
            "Envoyez le modèle exact voulu, par exemple : iPhone 13 Pro Max, iPhone 15 Pro, iPhone 16 Pro Max."
        )

    if category == "services":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 👨🏽‍💻\n"
            "Nous proposons plusieurs services : installation Windows, Pack Office, site web, application mobile, automatisation, cybersécurité.\n"
            "Dites-moi le service voulu et je vous donne le prix."
        )

    if category == "electromenager":
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}. 🏠\n"
            "Nous avons plusieurs articles électroménagers : frigo, congélateur, split/climatiseur, micro-onde, machine à laver.\n"
            "Dites-moi l’article voulu ou envoyez la capacité/taille."
        )

    return ""

def context_reply(state: Dict, chat_id: str) -> str:
    p = product_context_reply(state, chat_id)
    if p:
        return p

    c = category_context_reply(state, chat_id)
    if c:
        return c

    label = state.get("campaign_label")
    if label:
        return (
            f"Bonjour 👋 Vous venez sûrement de la {label}.\n"
            "Dites-moi exactement ce que vous voulez savoir : prix, disponibilité, livraison ou commande."
        )

    return ""

def generate_smart_reply(message: str, chat_id: str = "default") -> Dict:
    state = get_state(chat_id)
    msg_norm = normalize(message)

    # 1) Pub Facebook inconnue : on bloque pour éviter une réponse fausse.
    if state.get("needs_campaign_label"):
        result = unknown_campaign_admin_reply(state)
        record_unknown_message(message, chat_id, "unknown_facebook_campaign_waiting_admin", state, result)
        return result

    has_campaign_context = bool(state.get("campaign_id") or state.get("campaign_label"))

    # 2) Si la pub est connue et le client est vague, utiliser le contexte pub.
    if has_campaign_context and is_greeting(msg_norm):
        reply = context_reply(state, chat_id)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.93,
                "intent": "campaign_context_greeting",
                "safe_to_auto_send": True,
                "debug": {
                    "used_campaign_context": True,
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label")
                }
            }

    if has_campaign_context and is_vague_context_message(msg_norm):
        reply = context_reply(state, chat_id)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.92,
                "intent": "campaign_context_reply",
                "safe_to_auto_send": True,
                "debug": {
                    "used_campaign_context": True,
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label"),
                    "campaign_category": state.get("campaign_category")
                }
            }

    # 3) Banque intelligente pour les questions commerciales générales.
    bank = try_intent_bank_reply(message, chat_id=chat_id)
    if should_return_bank_before_product(bank):
        return bank

    # 4) Moteur produit existant.
    result = generate_reply(message, chat_id=chat_id)

    # 5) Si le moteur produit est vague mais que la banque a compris, utiliser la banque.
    if result.get("intent") in {"clarify_product", "vague_price", "smalltalk_or_noise"} and bank:
        return bank

    # 6) Si contexte pub connu mais le moteur est vague, revenir au contexte.
    if has_campaign_context and result.get("intent") in {"clarify_product", "vague_price", "smalltalk_or_noise"}:
        reply = context_reply(state, chat_id)
        if reply:
            return {
                "reply": reply,
                "confidence": 0.90,
                "intent": "campaign_context_fallback",
                "safe_to_auto_send": True,
                "debug": {
                    "original_intent": result.get("intent"),
                    "used_campaign_context": True,
                    "campaign_id": state.get("campaign_id"),
                    "campaign_label": state.get("campaign_label")
                }
            }

    # 7) Enregistrer les incompris pour apprentissage.
    try:
        conf = float(result.get("confidence", 0))
    except Exception:
        conf = 0

    if result.get("intent") in {"clarify_product", "smalltalk_or_noise"} or conf < 0.50:
        record_unknown_message(message, chat_id, "low_confidence_or_clarify", state, result)

    return result
